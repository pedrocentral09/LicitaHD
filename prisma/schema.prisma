generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// -------------------------------------------------------------
// Módulo: Autenticação (Basic Auth/Audit)
// -------------------------------------------------------------
enum UserRole {
  GOD
  OPERATOR
  BUYER
  LOGISTICS
}

model User {
  id           String   @id @default(uuid())
  name         String
  username     String   @unique
  email        String?  @unique
  passwordHash String
  role         UserRole @default(OPERATOR)
  createdAt    DateTime @default(now())

  validatedOrders PurchaseOrder[] @relation("UserValidation")
}

// -------------------------------------------------------------
// Módulo: Organizações (Prefeituras/Órgãos)
// -------------------------------------------------------------
model Organization {
  id        String   @id @default(uuid())
  name      String
  cnpj      String?  @unique
  uf        String?  @db.VarChar(2)
  isAiGenerated Boolean @default(false)
  createdAt DateTime @default(now())

  purchaseOrders    PurchaseOrder[]
  procurementGroups ProcurementGroup[]
  accountReceivables AccountReceivable[]
}

// -------------------------------------------------------------
// Módulo: Pedidos (Ordens de Compra Físicas / Empenhos)
// -------------------------------------------------------------
model PurchaseOrder {
  id             String      @id @default(uuid())
  documentNumber String
  status         OrderStatus @default(DRAFT)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  validatorId String?
  validator   User?   @relation("UserValidation", fields: [validatorId], references: [id])

  // Rastreio em Tela
  operatorName String?

  // Vendedor / Comercial
  sellerName String?

  issuedAt  DateTime?
  margin    Float?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  items PurchaseItem[]
  shipments Shipment[]
  accountReceivables AccountReceivable[]

  @@unique([organizationId, documentNumber])
}

enum OrderStatus {
  DRAFT
  VALIDATED
  QUOTED
  PARTIAL
  RECEIVED
  DELIVERED
  CANCELED
}

// -------------------------------------------------------------
// Módulo: Item de Compra
// -------------------------------------------------------------
model PurchaseItem {
  id              String @id @default(uuid())
  description     String
  quantity        Float
  unitPriceReturn Float
  active          Boolean   @default(true)

  // Campos de precificação e entrega
  costPrice        Float?
  taxPercent       Float?    @default(0)
  conversionFactor Float     @default(1)
  expectedDelivery DateTime?
  notes            String?

  // Campos de origem e titularidade
  buyingLocation   String?
  ownership        String?

  // Nota Fiscal de Venda
  invoiceNumber    String?

  // Entrega Granular
  receivedAt       DateTime?
  expectedCustomerDelivery DateTime?
  deliveredToCustomerAt    DateTime?

  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])

  procurementId    String?
  procurementGroup ProcurementGroup? @relation(fields: [procurementId], references: [id])

  shipmentItems    ShipmentItem[]
}

// -------------------------------------------------------------
// Módulo: Cotação/Agrupamento (O "Merge")
// -------------------------------------------------------------
model ProcurementGroup {
  id          String @id @default(uuid())
  description String

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  items PurchaseItem[]

  @@unique([organizationId, description])
}

// -------------------------------------------------------------
// Módulo: Financeiro (Contas a Receber)
// -------------------------------------------------------------
model AccountReceivable {
  id          String   @id @default(uuid())
  title       String
  amount      Float
  dueDate     DateTime
  paidAt      DateTime?
  status      ReceivableStatus @default(PENDING)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  purchaseOrderId String?
  purchaseOrder   PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum ReceivableStatus {
  PENDING
  PAID
  OVERDUE
}

// -------------------------------------------------------------
// Módulo: Remessas (Entregas Fracionadas)
// -------------------------------------------------------------
model Shipment {
  id              String         @id @default(uuid())
  shipmentNumber  Int
  invoiceNumber   String?
  status          ShipmentStatus @default(PENDING)
  notes           String?

  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])

  dispatchedAt    DateTime?
  deliveredAt     DateTime?
  createdAt       DateTime @default(now())

  items ShipmentItem[]
}

enum ShipmentStatus {
  PENDING
  DISPATCHED
  DELIVERED
}

model ShipmentItem {
  id             String @id @default(uuid())
  quantity       Float

  shipmentId     String
  shipment       Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  purchaseItemId String
  purchaseItem   PurchaseItem @relation(fields: [purchaseItemId], references: [id])
}
